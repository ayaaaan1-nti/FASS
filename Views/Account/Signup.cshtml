@page
@using FASS.Views.Account
@model FASS.Views.Account.SignupModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - FASS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/Signup.css" rel="stylesheet" />
</head>
<body>
    <div class="signup-wrapper">
        <!-- Background Design Elements -->
        <div class="bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
            <div class="shape shape-4"></div>
        </div>

        <div class="signup-container">
            <!-- Top-Right Login Button -->
            <a class="btn-login-redirect" asp-page="/Account/Login">
                <i class="fas fa-sign-in-alt"></i>
                <span>Sign In</span>
            </a>

            <!-- Left Panel - Branding -->
            <div class="signup-branding">
                <div class="brand-content">
                    <div class="brand-icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h1 class="brand-title">FASS<span>Hub</span></h1>
                    <p class="brand-subtitle">Join our growing community</p>
                    
                    <div class="brand-stats">
                        <div class="stat-item">
                            <span class="stat-number">15K+</span>
                            <span class="stat-label">Members</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-number">8K+</span>
                            <span class="stat-label">Projects</span>
                        </div>
                        <div class="stat-divider"></div>
                        <div class="stat-item">
                            <span class="stat-number">4.9★</span>
                            <span class="stat-label">Rating</span>
                        </div>
                    </div>

                    <div class="brand-features">
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Free to join</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Connect with experts</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-check-circle"></i>
                            <span>Build your career</span>
                        </div>
                    </div>

                    <div class="brand-testimonial">
                        <div class="testimonial-avatars">
                            <img src="https://i.pravatar.cc/40?img=5" alt="User" />
                            <img src="https://i.pravatar.cc/40?img=6" alt="User" />
                            <img src="https://i.pravatar.cc/40?img=7" alt="User" />
                            <img src="https://i.pravatar.cc/40?img=8" alt="User" />
                            <span class="avatar-count">+5k</span>
                        </div>
                        <p class="testimonial-text">"Join thousands who trust FASS for their success"</p>
                    </div>
                </div>
            </div>

            <!-- Right Panel - Signup Form -->
            <div class="signup-form-panel">
                <div class="form-header">
                    <h2>Create Account</h2>
                    <p>Start your journey with FASS today</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-custom alert-error">
                        <i class="fas fa-exclamation-circle"></i>
                        <div asp-validation-summary="All" class="error-message"></div>
                        <button type="button" class="alert-close" onclick="this.parentElement.remove()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }

                <form method="post" class="signup-form" id="signupForm">
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-user"></i>
                            </span>
                            <input asp-for="SignupViewModel.FullName" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.FullName">Full Name</label>
                        </div>
                        <span asp-validation-for="SignupViewModel.FullName" class="validation-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-envelope"></i>
                            </span>
                            <input asp-for="SignupViewModel.Email" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.Email">Email Address</label>
                        </div>
                        <span asp-validation-for="SignupViewModel.Email" class="validation-error"></span>
                    </div>

                    <!-- Username -->
                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-at"></i>
                            </span>
                            <input asp-for="SignupViewModel.Username" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.Username">Username</label>
                        </div>
                        <span asp-validation-for="SignupViewModel.Username" class="validation-error"></span>
                        <div class="field-hint">
                            <i class="fas fa-info-circle"></i>
                            <span>Choose a unique username (3-20 characters)</span>
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input asp-for="SignupViewModel.Password" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.Password">Password</label>
                            <button type="button" class="password-toggle" onclick="togglePasswordVisibility(this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="SignupViewModel.Password" class="validation-error"></span>
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar">
                                <div class="strength-progress" id="strengthProgress"></div>
                            </div>
                            <span class="strength-text" id="strengthText">Enter a strong password</span>
                        </div>
                        <div class="password-requirements">
                            <div class="requirement" id="reqLength">
                                <i class="fas fa-circle"></i>
                                <span>At least 8 characters</span>
                            </div>
                            <div class="requirement" id="reqNumber">
                                <i class="fas fa-circle"></i>
                                <span>Contains a number</span>
                            </div>
                            <div class="requirement" id="reqSpecial">
                                <i class="fas fa-circle"></i>
                                <span>Contains a special character</span>
                            </div>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-group">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-check-circle"></i>
                            </span>
                            <input asp-for="SignupViewModel.ConfirmPassword" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.ConfirmPassword">Confirm Password</label>
                        </div>
                        <span asp-validation-for="SignupViewModel.ConfirmPassword" class="validation-error"></span>
                    </div>

                    <!-- Role Selection -->
                    <div class="form-group">
                        <label class="role-label">I want to</label>
                        <div class="role-options">
                            <label class="role-card">
                                <input type="radio" asp-for="SignupViewModel.Role" value="Freelancer" checked />
                                <div class="card-content">
                                    <i class="fas fa-user-tie"></i>
                                    <span>Work as Freelancer</span>
                                    <small>Find projects & earn</small>
                                </div>
                            </label>
                            <label class="role-card">
                                <input type="radio" asp-for="SignupViewModel.Role" value="Client" />
                                <div class="card-content">
                                    <i class="fas fa-briefcase"></i>
                                    <span>Hire Freelancers</span>
                                    <small>Post projects & hire</small>
                                </div>
                            </label>
                        </div>
                        <span asp-validation-for="SignupViewModel.Role" class="validation-error"></span>
                    </div>

                    <!-- Skills (Freelancer only) -->
                    <div class="form-group" id="skillsGroup">
                        <div class="input-group">
                            <span class="input-icon">
                                <i class="fas fa-tags"></i>
                            </span>
                            <input asp-for="SignupViewModel.Skills" class="form-control" placeholder=" " />
                            <label asp-for="SignupViewModel.Skills">Skills (comma separated)</label>
                        </div>
                        <span asp-validation-for="SignupViewModel.Skills" class="validation-error"></span>
                        <div class="field-hint">
                            <i class="fas fa-info-circle"></i>
                            <span>Example: Web Development, UI/UX, Python</span>
                        </div>
                    </div>

                    <!-- Terms & Conditions -->
                    <div class="form-group">
                        <label class="checkbox-custom">
                            <input asp-for="SignupViewModel.AgreeToTerms" />
                            <span class="checkmark"></span>
                            <span class="checkbox-label">
                                I agree to the <a href="#" onclick="return false;">Terms of Service</a> and <a href="#" onclick="return false;">Privacy Policy</a>
                            </span>
                        </label>
                        <span asp-validation-for="SignupViewModel.AgreeToTerms" class="validation-error"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn-signup" id="signupSubmitButton">
                        <span>Create Account</span>
                        <i class="fas fa-arrow-right"></i>
                    </button>

                    <!-- Divider -->
                    <div class="divider">
                        <span>Or continue with</span>
                    </div>

                    <!-- Social Signup -->
                    <div class="social-signup">
                        <button type="button" class="social-btn google">
                            <i class="fab fa-google"></i>
                            Google
                        </button>
                        <button type="button" class="social-btn github">
                            <i class="fab fa-github"></i>
                            GitHub
                        </button>
                        <button type="button" class="social-btn linkedin">
                            <i class="fab fa-linkedin-in"></i>
                            LinkedIn
                        </button>
                    </div>

                    <!-- Login Prompt -->
                    <p class="login-prompt">
                        Already have an account? <a asp-page="/Account/Login">Sign in here</a>
                    </p>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    }

</body>
</html>